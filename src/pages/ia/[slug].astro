---
import { getCollection, render } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Hero from '~/components/sections/Hero.astro';
import Section from '~/components/ui/Section.astro';
import SectionDivider from '~/components/ui/SectionDivider.astro';
import Card from '~/components/ui/Card.astro';
import RelatedGrid from '~/components/sections/RelatedGrid.astro';
import OfferCard from '~/components/cards/OfferCard.astro';
import CTASection from '~/components/sections/CTASection.astro';
import Chip from '~/components/ui/Chip.astro';
import Icon from '~/components/ui/Icon.astro';
import {
  softwareApplicationLd,
  breadcrumbLd,
  canonicalUrl,
} from '~/lib/seo';
import { t, localizeUrl, type Lang } from '~/lib/i18n';

export async function getStaticPaths() {
  const products = await getCollection('aiProducts');
  return products.map((p) => ({
    params: { slug: p.id },
    props: { entry: p },
  }));
}

const { entry } = Astro.props;
const lang: Lang = (Astro.url.pathname.startsWith('/en')) ? 'en' : 'fr';
const { Content } = await render(entry);

const all = await getCollection('aiProducts');
const related = (entry.data.relatedSlugs ?? [])
  .map((slug) => all.find((p) => p.id === slug))
  .filter((x): x is NonNullable<typeof x> => Boolean(x));

const fallbackRelated =
  related.length > 0
    ? []
    : all.filter((p) => p.id !== entry.id).slice(0, 2);

const relatedFinal = related.length > 0 ? related : fallbackRelated;

const url = canonicalUrl(`/ia/${entry.id}`, lang);

const jsonLd: object[] = [
  softwareApplicationLd({
    name: entry.data.name,
    description: entry.data.summary,
    url,
    category: 'BusinessApplication',
  }),
  breadcrumbLd([
    { name: t(lang, 'brand'), url: canonicalUrl('/', lang) },
    { name: t(lang, 'family.ia'), url: canonicalUrl('/ia', lang) },
    { name: entry.data.name, url },
  ]),
];
---

<BaseLayout
  lang={lang}
  path={`/ia/${entry.id}`}
  title={`${entry.data.name} — ${entry.data.tagline}`}
  description={entry.data.summary}
  jsonLd={jsonLd}
>
  <Hero
    variant="page"
    family="ia"
    kicker={t(lang, 'family.ia')}
    title={entry.data.name}
    subtitle={entry.data.tagline}
    ctaLabel={t(lang, 'cta.demo')}
    ctaHref={localizeUrl(`/contact?type=demo&product=${entry.id}`, lang)}
    secondaryCtaLabel={t(lang, 'cta.contact')}
    secondaryCtaHref={localizeUrl(`/contact?product=${entry.id}`, lang)}
  />

  {/* === Tags + résumé encadré === */}
  <Section reveal={false}>
    <div class="flex flex-wrap gap-2 mb-8 reveal">
      <Chip>{t(lang, `capability.${entry.data.capability}`)}</Chip>
    </div>
    <div class="max-w-4xl reveal">
      <Card accent="ia">
        <div class="p-7 md:p-8">
          <p class="text-h4 text-ink-100 leading-relaxed font-light">{entry.data.summary}</p>
        </div>
      </Card>
    </div>
  </Section>

  <SectionDivider />

  {/* === Comment ça marche : étapes en cards numérotées === */}
  <Section title={t(lang, 'detail.howItWorks')} family="ia">
    <ol class="grid md:grid-cols-3 gap-6 list-none p-0">
      {entry.data.howItWorks.map((step, i) => (
        <li class="reveal relative pt-4" style={`--reveal-delay: ${i * 100}ms`}>
          {/* Badge positionné sur le <li> (overflow visible) pour éviter le clip
              du card (overflow-hidden). */}
          <span
            class="absolute top-0 left-6 z-10 w-9 h-9 rounded-full bg-coral-400 text-ink-950 flex items-center justify-center text-small font-bold shadow-[0_0_0_4px_var(--surface-page)]"
            aria-hidden="true"
          >
            {step.step}
          </span>
          <Card interactive spotlight class="h-full">
            <div class="p-7 pt-9 h-full">
              <h3 class="text-h4 font-semibold text-ink-50 mb-2 tracking-tight">{step.title}</h3>
              <p class="text-small text-ink-200 leading-relaxed">{step.desc}</p>
            </div>
          </Card>
        </li>
      ))}
    </ol>
  </Section>

  <SectionDivider />

  {/* === Cas d'usage : grille de cards === */}
  <Section title={t(lang, 'detail.useCases')}>
    <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 list-none p-0">
      {entry.data.useCases.map((uc, i) => (
        <li class="reveal" style={`--reveal-delay: ${i * 60}ms`}>
          <Card interactive class="h-full">
            <div class="p-5 flex items-start gap-3">
              <span class="mt-1.5 w-2 h-2 rounded-full bg-coral-400 shrink-0 shadow-[0_0_8px_rgba(255,61,127,0.6)]"></span>
              <span class="text-base text-ink-100">{uc}</span>
            </div>
          </Card>
        </li>
      ))}
    </ul>
  </Section>

  {entry.data.integrations && entry.data.integrations.length > 0 && (
    <>
      <SectionDivider />
      <Section title={t(lang, 'detail.integrations')}>
        <div class="reveal">
          <Card>
            <div class="p-6 md:p-8">
              <div class="flex flex-wrap gap-3">
                {entry.data.integrations.map((i) => (
                  <span class="inline-flex items-center gap-1.5 px-4 py-2 border border-ink-700 rounded-md text-small text-ink-100 bg-ink-950/60 font-mono">
                    <span class="w-1.5 h-1.5 rounded-full bg-coral-400"></span>
                    {i}
                  </span>
                ))}
              </div>
            </div>
          </Card>
        </div>
      </Section>
    </>
  )}

  <Section>
    <div class="max-w-3xl reveal">
      <Card>
        <div class="p-8 md:p-10 prose prose-ink text-base text-ink-200 leading-relaxed">
          <Content />
        </div>
      </Card>
    </div>
  </Section>

  {relatedFinal.length > 0 && (
    <>
      <SectionDivider />
      <RelatedGrid title={t(lang, 'detail.related')}>
        {relatedFinal.map((p) => (
          <OfferCard
            variant="ai"
            name={p.data.name}
            tagline={p.data.tagline}
            icon={p.data.icon}
            tags={[t(lang, `capability.${p.data.capability}`)]}
            href={localizeUrl(`/ia/${p.id}`, lang)}
          />
        ))}
      </RelatedGrid>
    </>
  )}

  <CTASection
    title={lang === 'fr' ? 'Voir une démo en conditions réelles' : 'See a real-world demo'}
    subtitle={lang === 'fr'
      ? '30 à 45 minutes en visio, adaptées à votre contexte métier.'
      : '30–45 minutes online, tailored to your business context.'}
    family="ia"
    ctaLabel={t(lang, 'cta.demo')}
    ctaHref={localizeUrl(`/contact?type=demo&product=${entry.id}`, lang)}
    secondaryCtaLabel={t(lang, 'cta.contact')}
    secondaryCtaHref={localizeUrl('/contact', lang)}
  />
</BaseLayout>
