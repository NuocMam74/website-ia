---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Hero from '~/components/sections/Hero.astro';
import Section from '~/components/ui/Section.astro';
import RelatedGrid from '~/components/sections/RelatedGrid.astro';
import TemplateCard from '~/components/cards/TemplateCard.astro';
import AddToCartButton from '~/components/islands/AddToCartButton.tsx';
import Icon from '~/components/ui/Icon.astro';
import {
  productLd,
  breadcrumbLd,
  canonicalUrl,
} from '~/lib/seo';
import { t, localizeUrl, formatPrice, type Lang } from '~/lib/i18n';

export async function getStaticPaths() {
  const templates = await getCollection('templates');
  return templates.map((tpl) => ({
    params: { slug: tpl.id },
    props: { entry: tpl },
  }));
}

const { entry } = Astro.props;
const lang: Lang = (Astro.url.pathname.startsWith('/en')) ? 'en' : 'fr';

const all = await getCollection('templates');
const related = (entry.data.relatedSlugs ?? [])
  .map((slug) => all.find((t) => t.id === slug))
  .filter((x): x is NonNullable<typeof x> => Boolean(x));

const fallbackRelated =
  related.length > 0
    ? []
    : all
        .filter((t) => t.id !== entry.id && t.data.norm === entry.data.norm)
        .slice(0, 2);

const relatedFinal = related.length > 0 ? related : fallbackRelated;

const url = canonicalUrl(`/templates/${entry.id}`, lang);

const jsonLd: object[] = [
  productLd({
    name: entry.data.name,
    description: entry.data.summary,
    url,
    priceEUR: entry.data.priceEUR,
    sku: entry.id,
  }),
  breadcrumbLd([
    { name: t(lang, 'brand'), url: canonicalUrl('/', lang) },
    {
      name: t(lang, 'family.templates'),
      url: canonicalUrl('/templates', lang),
    },
    { name: entry.data.name, url },
  ]),
];
---

<BaseLayout
  lang={lang}
  path={`/templates/${entry.id}`}
  title={`${entry.data.name} — ${entry.data.summary}`}
  description={entry.data.summary}
  jsonLd={jsonLd}
>
  <Hero
    variant="page"
    family="templates"
    kicker={t(lang, 'family.templates')}
    title={entry.data.name}
    subtitle={entry.data.summary}
  />

  <Section>
    <div class="grid lg:grid-cols-[2fr_1fr] gap-10">
      <div>
        <p class="text-base text-ink-200 leading-relaxed mb-8">{entry.data.longDescription}</p>

        <h2 class="text-h2 font-medium text-ink-50 mb-4">{t(lang, 'template.contents')}</h2>
        <ul class="space-y-2 mb-10">
          {entry.data.contents.map((c) => (
            <li class="flex items-start gap-2">
              <Icon name="check" size={18} class="text-amber-600 mt-0.5 shrink-0" />
              <span class="text-base text-ink-100">{c}</span>
            </li>
          ))}
        </ul>

        <dl class="grid sm:grid-cols-3 gap-4 text-small">
          <div class="p-4 border border-ink-800 rounded-md bg-ink-900">
            <dt class="text-xs text-ink-500 mb-1">{t(lang, 'template.format')}</dt>
            <dd class="text-ink-50 font-medium">{entry.data.fileFormat}</dd>
          </div>
          <div class="p-4 border border-ink-800 rounded-md bg-ink-900">
            <dt class="text-xs text-ink-500 mb-1">{t(lang, 'template.version')}</dt>
            <dd class="text-ink-50 font-medium">{entry.data.version}</dd>
          </div>
          <div class="p-4 border border-ink-800 rounded-md bg-ink-900">
            <dt class="text-xs text-ink-500 mb-1">{t(lang, 'norm.' + entry.data.norm)}</dt>
            <dd class="text-ink-50 font-medium">{t(lang, `norm.${entry.data.norm}`)}</dd>
          </div>
        </dl>

        <p class="mt-6 text-small text-ink-300 italic">
          <Icon name="lock-keyhole" size={14} class="inline -mt-0.5 mr-1" />
          {entry.data.license}
        </p>
      </div>

      <aside class="lg:sticky lg:top-6 self-start">
        <div class="border border-ink-800 rounded-lg bg-ink-900 p-6">
          <div class="pb-4 border-b border-ink-800">
            <div class="text-xs text-ink-500 uppercase tracking-wider mb-1">
              {t(lang, 'template.priceLabel')}
            </div>
            <div class="text-display font-medium text-ink-50">
              {formatPrice(entry.data.priceEUR, lang)}
            </div>
          </div>

          <div class="mt-4 space-y-3">
            <AddToCartButton
              client:load
              slug={entry.id}
              name={entry.data.name}
              priceEUR={entry.data.priceEUR}
              labelAdd={t(lang, 'cta.addToCart')}
              labelAdded={lang === 'fr' ? 'Ajouté' : 'Added'}
            />
            <a
              href={localizeUrl('/panier', lang)}
              class="block w-full text-center px-4 py-2 text-small font-medium text-ink-50 border border-ink-700 hover:bg-ink-800 rounded-md transition-colors"
            >
              {t(lang, 'cta.buyNow')}
            </a>
          </div>

          {entry.data.sampleUrl && (
            <a
              href={entry.data.sampleUrl}
              target="_blank"
              rel="noopener"
              class="block mt-4 text-small text-ink-300 hover:text-ink-50 text-center"
            >
              <Icon name="file-text" size={14} class="inline -mt-0.5 mr-1" />
              {lang === 'fr' ? 'Voir un extrait' : 'See a sample'}
            </a>
          )}
        </div>
      </aside>
    </div>
  </Section>

  {relatedFinal.length > 0 && (
    <RelatedGrid title={t(lang, 'detail.related')}>
      {relatedFinal.map((t) => (
        <TemplateCard
          slug={t.id}
          name={t.data.name}
          summary={t.data.summary}
          icon={t.data.icon}
          priceEUR={t.data.priceEUR}
          href={localizeUrl(`/templates/${t.id}`, lang)}
          lang={lang}
        />
      ))}
    </RelatedGrid>
  )}
</BaseLayout>
