---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Hero from '~/components/sections/Hero.astro';
import Section from '~/components/ui/Section.astro';
import LegalNotice from '~/components/ui/LegalNotice.astro';
import type { Lang } from '~/lib/i18n';

const lang: Lang = (Astro.url.pathname.startsWith('/en')) ? 'en' : 'fr';
---

<BaseLayout
  lang={lang}
  path="/cookies"
  title={lang === 'fr' ? 'Politique cookies' : 'Cookie policy'}
  description={lang === 'fr'
    ? 'Quels cookies utilisons-nous et pourquoi.'
    : 'Which cookies we use and why.'}
  noindex
>
  <Hero variant="page" title={lang === 'fr' ? 'Politique cookies' : 'Cookie policy'} />
  <Section>
    <div class="max-w-3xl prose prose-ink text-base text-ink-200 leading-relaxed [&>h2]:text-h3 [&>h2]:font-medium [&>h2]:text-ink-50 [&>h2]:mt-8 [&>h2]:mb-3 [&>p]:mb-4">
      <LegalNotice lang={lang} />

      <h2>{lang === 'fr' ? 'Principe' : 'Principle'}</h2>
      <p>
        {lang === 'fr'
          ? 'Aucun cookie non essentiel n’est posé avant votre consentement explicite. Le refus est aussi simple que l’acceptation.'
          : 'No non-essential cookie is placed before your explicit consent. Refusing is as simple as accepting.'}
      </p>

      <h2>{lang === 'fr' ? 'Cookies essentiels' : 'Essential cookies'}</h2>
      <p>
        {lang === 'fr'
          ? 'Conservation locale du panier (clé `cart.v1`), conservation de votre choix de consentement (`cookies.consent.v1`). Ces données restent sur votre appareil.'
          : 'Local storage of the cart (`cart.v1` key), storage of your consent choice (`cookies.consent.v1`). These data stay on your device.'}
      </p>

      <h2>{lang === 'fr' ? 'Mesure d’audience' : 'Analytics'}</h2>
      <p>
        {lang === 'fr'
          ? 'Si vous acceptez, une solution de mesure d’audience respectueuse (à confirmer selon votre choix) collecte des statistiques anonymisées : pages vues, durée, événements de conversion.'
          : 'If you accept, a privacy-friendly analytics solution (to be confirmed based on your choice) collects anonymised statistics: page views, duration, conversion events.'}
      </p>

      <h2>{lang === 'fr' ? 'Modifier votre choix' : 'Change your choice'}</h2>
      <p>
        {lang === 'fr'
          ? 'Vous pouvez à tout moment modifier votre choix en effaçant le stockage local du site dans les paramètres de votre navigateur.'
          : 'You can change your choice at any time by clearing the site’s local storage in your browser settings.'}
      </p>
    </div>
  </Section>
</BaseLayout>
