---
import { getCollection, render } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Hero from '~/components/sections/Hero.astro';
import Section from '~/components/ui/Section.astro';
import SectionDivider from '~/components/ui/SectionDivider.astro';
import Card from '~/components/ui/Card.astro';
import CTASection from '~/components/sections/CTASection.astro';
import Chip from '~/components/ui/Chip.astro';
import Icon from '~/components/ui/Icon.astro';
import DashboardCard from '~/components/mockups/DashboardCard.astro';
import { breadcrumbLd, canonicalUrl } from '~/lib/seo';
import { t, localizeUrl, type Lang } from '~/lib/i18n';

export async function getStaticPaths() {
  const cases = await getCollection('caseStudies');
  return cases.map((c) => ({ params: { slug: c.id }, props: { entry: c } }));
}

const { entry } = Astro.props;
const lang: Lang = (Astro.url.pathname.startsWith('/en')) ? 'en' : 'fr';
const { Content } = await render(entry);
const url = canonicalUrl(`/references/${entry.id}`, lang);
---

<BaseLayout
  lang={lang}
  path={`/references/${entry.id}`}
  title={entry.data.title}
  description={entry.data.challenge.slice(0, 160)}
  jsonLd={breadcrumbLd([
    { name: t(lang, 'brand'), url: canonicalUrl('/', lang) },
    { name: t(lang, 'nav.references'), url: canonicalUrl('/references', lang) },
    { name: entry.data.title, url },
  ])}
>
  <Hero
    variant="page"
    family={entry.data.relatedFamily}
    kicker={t(lang, 'nav.references')}
    title={entry.data.title}
  />

  <Section>
    <div class="flex flex-wrap gap-2 mb-8">
      <Chip>{entry.data.sector}</Chip>
      <Chip>{entry.data.client}</Chip>
      {entry.data.draft && (
        <span class="px-2 py-0.5 text-xs uppercase tracking-wide text-coral-300 bg-coral-500/10 rounded">
          {lang === 'fr' ? 'À valider' : 'To validate'}
        </span>
      )}
    </div>

    <div class="grid lg:grid-cols-[2fr_1fr] gap-8">
      <div class="space-y-6">
        <div class="reveal">
          <Card>
            <div class="p-7 md:p-8">
              <div class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-coral-500/10 ring-1 ring-coral-400/30 text-coral-300 mb-4">
                <Icon name="bell" size={18} />
              </div>
              <h2 class="text-h2 font-semibold text-ink-50 mb-3 tracking-tight">
                {lang === 'fr' ? 'Le défi' : 'The challenge'}
              </h2>
              <p class="text-base text-ink-200 leading-relaxed">{entry.data.challenge}</p>
            </div>
          </Card>
        </div>
        <div class="reveal" style="--reveal-delay: 100ms">
          <Card accent={entry.data.relatedFamily}>
            <div class="p-7 md:p-8">
              <div class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-teal-500/10 ring-1 ring-teal-400/30 text-teal-300 mb-4">
                <Icon name="wrench" size={18} />
              </div>
              <h2 class="text-h2 font-semibold text-ink-50 mb-3 tracking-tight">
                {lang === 'fr' ? 'Notre approche' : 'Our approach'}
              </h2>
              <p class="text-base text-ink-200 leading-relaxed">{entry.data.approach}</p>
            </div>
          </Card>
        </div>
        <div class="reveal" style="--reveal-delay: 200ms">
          <Card>
            <div class="p-7 md:p-8 prose prose-ink max-w-none text-base text-ink-200 leading-relaxed">
              <Content />
            </div>
          </Card>
        </div>
      </div>

      <aside class="self-start space-y-6 lg:sticky lg:top-24">
        <div class="border border-ink-800 rounded-xl bg-ink-900 p-6">
          <div class="flex items-center gap-2 mb-4">
            <div class="w-1 h-5 rounded-full bg-teal-400"></div>
            <h3 class="text-h4 font-semibold text-ink-50 tracking-tight">
              {lang === 'fr' ? 'Résultats mesurés' : 'Measured results'}
            </h3>
          </div>
          <ul class="space-y-5">
            {entry.data.results.map((r) => (
              <li class="reveal">
                <div class="text-display font-semibold text-gradient-cyan">{r.value}</div>
                <div class="text-small text-ink-300 mt-1">{r.label}</div>
              </li>
            ))}
          </ul>
        </div>

        <div class="border border-ink-800 rounded-xl bg-ink-900 p-6">
          <h3 class="text-h4 font-semibold text-ink-50 mb-4 tracking-tight">
            {lang === 'fr' ? 'Contexte projet' : 'Project context'}
          </h3>
          <dl class="space-y-3 text-small">
            <div class="flex items-center justify-between">
              <dt class="text-ink-400">{lang === 'fr' ? 'Secteur' : 'Sector'}</dt>
              <dd class="text-ink-100 font-medium">{entry.data.sector}</dd>
            </div>
            <div class="flex items-center justify-between">
              <dt class="text-ink-400">{lang === 'fr' ? 'Client' : 'Client'}</dt>
              <dd class="text-ink-100 font-medium text-right max-w-[60%]">{entry.data.client}</dd>
            </div>
            <div class="flex items-center justify-between">
              <dt class="text-ink-400">{lang === 'fr' ? 'Année' : 'Year'}</dt>
              <dd class="text-ink-100 font-medium">{new Date(entry.data.publishedAt).getFullYear()}</dd>
            </div>
          </dl>
        </div>
      </aside>
    </div>
  </Section>

  <SectionDivider />

  {/* === Aperçu du livrable === */}
  <Section
    title={lang === 'fr' ? 'Aperçu du livrable' : 'Deliverable preview'}
    subtitle={lang === 'fr'
      ? 'Le tableau de bord déployé côté client (interface anonymisée).'
      : 'The dashboard deployed at the client (anonymised interface).'}
    surface="muted"
  >
    <div class="max-w-3xl mx-auto reveal">
      <DashboardCard />
      <p class="mt-4 text-xs text-ink-500 text-center italic">
        {lang === 'fr'
          ? 'Capture d’écran représentative à des fins illustratives. Les données réelles restent confidentielles.'
          : 'Representative screenshot for illustration. Real data remains confidential.'}
      </p>
    </div>
  </Section>

  <SectionDivider />

  {/* === Étapes du projet === */}
  <Section
    title={lang === 'fr' ? 'Les étapes clés du projet' : 'Key project steps'}
  >
    <ol class="grid grid-cols-1 md:grid-cols-4 gap-5">
      {[
        { n: '01', t: lang === 'fr' ? 'Cadrage' : 'Scoping', d: lang === 'fr' ? '2 semaines' : '2 weeks' },
        { n: '02', t: 'POC', d: lang === 'fr' ? '6 semaines' : '6 weeks' },
        { n: '03', t: lang === 'fr' ? 'Déploiement' : 'Rollout', d: lang === 'fr' ? '3 mois' : '3 months' },
        { n: '04', t: lang === 'fr' ? 'Run & support' : 'Run & support', d: lang === 'fr' ? 'En continu' : 'Ongoing' },
      ].map((s, i) => (
        <li class="reveal" style={`--reveal-delay: ${i * 80}ms`}>
          <div class="p-6 border border-ink-800 rounded-xl bg-ink-900 hover-lift hover:border-ink-700">
            <div class="text-h2 font-light text-ink-600 tracking-tight mb-2">{s.n}</div>
            <div class="text-base font-semibold text-ink-50">{s.t}</div>
            <div class="text-small text-ink-400 mt-0.5">{s.d}</div>
          </div>
        </li>
      ))}
    </ol>
  </Section>

  <CTASection
    title={lang === 'fr' ? 'Un cas similaire chez vous ?' : 'A similar case at your company?'}
    family={entry.data.relatedFamily}
    ctaLabel={t(lang, 'cta.contact')}
    ctaHref={localizeUrl('/contact', lang)}
  />
</BaseLayout>
