---
/**
 * Mock "matrice de traçabilité" — graphe simplifié exigence → design →
 * test, rendu en SVG.
 */
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<div class:list={['relative bg-ink-900 border border-ink-700 rounded-xl overflow-hidden card-shadow', className]}>
  <div class="flex items-center justify-between px-4 py-2.5 border-b border-ink-800 bg-ink-950/60">
    <span class="text-[10px] font-mono text-ink-400">Traçabilité · REQ-1024</span>
    <span class="text-[10px] text-amber-300 font-medium">3 niveaux</span>
  </div>

  <div class="p-5">
    <svg viewBox="0 0 320 200" class="w-full h-auto" aria-hidden="true">
      <defs>
        <linearGradient id="trace-line" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#00D9FF" stop-opacity="0.4" />
          <stop offset="100%" stop-color="#00D9FF" stop-opacity="0.8" />
        </linearGradient>
      </defs>

      {/* Niveau 1 : Exigence */}
      <g>
        <rect x="10" y="80" width="80" height="40" rx="6" fill="#0F0F14" stroke="#00D9FF" stroke-width="1.5" />
        <text x="50" y="95" text-anchor="middle" fill="#66E5FF" font-size="8" font-family="monospace">REQ</text>
        <text x="50" y="108" text-anchor="middle" fill="#FAFAFC" font-size="9" font-weight="600">Exigence</text>
      </g>

      {/* Niveau 2 : Design */}
      <g>
        <rect x="120" y="20" width="80" height="40" rx="6" fill="#0F0F14" stroke="#2E2E36" stroke-width="1" />
        <text x="160" y="35" text-anchor="middle" fill="#74747F" font-size="8" font-family="monospace">DSG</text>
        <text x="160" y="48" text-anchor="middle" fill="#C2C2CC" font-size="9">Design</text>
      </g>
      <g>
        <rect x="120" y="80" width="80" height="40" rx="6" fill="#0F0F14" stroke="#2E2E36" stroke-width="1" />
        <text x="160" y="95" text-anchor="middle" fill="#74747F" font-size="8" font-family="monospace">DSG</text>
        <text x="160" y="108" text-anchor="middle" fill="#C2C2CC" font-size="9">Design</text>
      </g>
      <g>
        <rect x="120" y="140" width="80" height="40" rx="6" fill="#0F0F14" stroke="#2E2E36" stroke-width="1" />
        <text x="160" y="155" text-anchor="middle" fill="#74747F" font-size="8" font-family="monospace">DSG</text>
        <text x="160" y="168" text-anchor="middle" fill="#C2C2CC" font-size="9">Design</text>
      </g>

      {/* Niveau 3 : Tests */}
      <g>
        <rect x="230" y="20" width="80" height="40" rx="6" fill="#0F0F14" stroke="#1D9E75" stroke-width="1.5" />
        <text x="270" y="35" text-anchor="middle" fill="#5DCAA5" font-size="8" font-family="monospace">TST</text>
        <text x="270" y="48" text-anchor="middle" fill="#FAFAFC" font-size="9" font-weight="600">PASS</text>
      </g>
      <g>
        <rect x="230" y="80" width="80" height="40" rx="6" fill="#0F0F14" stroke="#1D9E75" stroke-width="1.5" />
        <text x="270" y="95" text-anchor="middle" fill="#5DCAA5" font-size="8" font-family="monospace">TST</text>
        <text x="270" y="108" text-anchor="middle" fill="#FAFAFC" font-size="9" font-weight="600">PASS</text>
      </g>
      <g>
        <rect x="230" y="140" width="80" height="40" rx="6" fill="#0F0F14" stroke="#FF3D7F" stroke-width="1.5" />
        <text x="270" y="155" text-anchor="middle" fill="#FF85B1" font-size="8" font-family="monospace">TST</text>
        <text x="270" y="168" text-anchor="middle" fill="#FFFFFF" font-size="9" font-weight="600">FAIL</text>
      </g>

      {/* Liens */}
      <g stroke="url(#trace-line)" stroke-width="1.5" fill="none">
        <line x1="90" y1="100" x2="120" y2="40" />
        <line x1="90" y1="100" x2="120" y2="100" />
        <line x1="90" y1="100" x2="120" y2="160" />
        <line x1="200" y1="40" x2="230" y2="40" />
        <line x1="200" y1="100" x2="230" y2="100" />
        <line x1="200" y1="160" x2="230" y2="160" stroke="#FF3D7F" stroke-dasharray="3 2" />
      </g>
    </svg>

    <div class="mt-2 grid grid-cols-3 gap-2 text-center text-[10px]">
      <div class="px-2 py-1 rounded bg-teal-500/10 text-teal-200">2 ✓ pass</div>
      <div class="px-2 py-1 rounded bg-coral-500/10 text-coral-200">1 ✗ fail</div>
      <div class="px-2 py-1 rounded bg-ink-800 text-ink-300">100% tracé</div>
    </div>
  </div>
</div>
