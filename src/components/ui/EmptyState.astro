---
/**
 * État vide affiché quand un filtre ne retourne aucun résultat
 * (cf. brief §11 : « Filtre sans résultat → état vide propre,
 * jamais de page fantôme »).
 */
import Button from './Button.astro';

interface Props {
  title?: string;
  message: string;
  ctaLabel?: string;
  ctaHref?: string;
  icon?: string;
}

const { title, message, ctaLabel, ctaHref, icon = 'sparkles' } = Astro.props;
---

<div class="mx-auto max-w-md text-center py-16 px-6">
  <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-ink-800 text-ink-500 mb-4">
    <slot name="icon">
      {/* Placeholder icon — overridable via slot for finer control */}
      <span aria-hidden="true" data-icon={icon}></span>
    </slot>
  </div>
  {title && <h3 class="text-h3 font-medium text-ink-50 mb-2">{title}</h3>}
  <p class="text-small text-ink-300">{message}</p>
  {ctaLabel && ctaHref && (
    <div class="mt-6">
      <Button href={ctaHref} variant="secondary" icon="arrow-right">
        {ctaLabel}
      </Button>
    </div>
  )}
</div>
