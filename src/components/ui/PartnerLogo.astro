---
/**
 * Logo géométrique pour partenaires — utilisé tant qu'on n'a pas les
 * vrais logos. Génère un monogramme SVG avec une géométrie unique par
 * partenaire (basée sur un hash simple du nom).
 */
interface Props {
  name: string;
  /** Tag de catégorie pour la couleur de fond. */
  category?: 'technology' | 'integrator' | 'certification' | 'community';
  size?: number;
}

const { name, category = 'technology', size = 64 } = Astro.props;

const initials = name
  .replace(/\[.*?\]/g, '')
  .trim()
  .split(/\s+/)
  .map((s) => s[0])
  .filter(Boolean)
  .slice(0, 2)
  .join('')
  .toUpperCase() || '?';

/* Hash très simple → permet de générer des formes "uniques" stables */
function hash(s: string): number {
  let h = 0;
  for (let i = 0; i < s.length; i++) h = (h * 31 + s.charCodeAt(i)) & 0xffffffff;
  return Math.abs(h);
}
const h = hash(name);

const palettes: Record<NonNullable<Props['category']>, { bg: string; border: string; text: string }> = {
  technology: { bg: 'from-teal-500/20 to-teal-700/10', border: 'border-teal-400/30', text: 'text-teal-100' },
  integrator: { bg: 'from-coral-500/20 to-coral-700/10', border: 'border-coral-400/30', text: 'text-coral-100' },
  certification: { bg: 'from-amber-500/20 to-amber-700/10', border: 'border-amber-400/30', text: 'text-amber-100' },
  community: { bg: 'from-ink-700 to-ink-800', border: 'border-ink-600', text: 'text-ink-100' },
};
const p = palettes[category];

/* Choisit une géométrie déco selon le hash */
const shape = h % 3;
---

<div
  class:list={[
    'relative inline-flex items-center justify-center rounded-xl border bg-gradient-to-br overflow-hidden font-semibold tracking-tight',
    p.bg,
    p.border,
    p.text,
  ]}
  style={`width: ${size}px; height: ${size}px;`}
  aria-hidden="true"
>
  {/* Géométrie de fond — varie par partenaire */}
  <svg viewBox="0 0 64 64" class="absolute inset-0 w-full h-full opacity-30">
    {shape === 0 && (
      <>
        <circle cx="48" cy="16" r="20" fill="currentColor" opacity="0.4" />
        <circle cx="14" cy="48" r="14" fill="currentColor" opacity="0.2" />
      </>
    )}
    {shape === 1 && (
      <>
        <rect x="-4" y="32" width="36" height="36" rx="6" transform="rotate(15 14 50)" fill="currentColor" opacity="0.3" />
        <rect x="32" y="-4" width="36" height="36" rx="6" transform="rotate(-10 50 14)" fill="currentColor" opacity="0.2" />
      </>
    )}
    {shape === 2 && (
      <>
        <path d="M 0 64 L 64 0 L 64 32 L 32 64 Z" fill="currentColor" opacity="0.3" />
        <circle cx="48" cy="48" r="10" fill="currentColor" opacity="0.4" />
      </>
    )}
  </svg>

  <span class="relative" style={`font-size: ${Math.round(size / 2.8)}px;`}>
    {initials}
  </span>
</div>
