---
/**
 * Boutons de partage social (LinkedIn, X, Mail) + copie de lien.
 * Génère des liens "share intents" — pas de tracker tiers, pas de JS lourd.
 *
 * Usage :
 *   <ShareButtons url={canonical} title={title} />
 */
interface Props {
  url: string;
  title: string;
  lang?: 'fr' | 'en';
}

const { url, title, lang = 'fr' } = Astro.props;

const enc = (s: string) => encodeURIComponent(s);

const channels = [
  {
    name: 'LinkedIn',
    href: `https://www.linkedin.com/sharing/share-offsite/?url=${enc(url)}`,
    icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14zM8.34 18V10.13H5.67V18h2.67zM7 8.92a1.55 1.55 0 1 0 0-3.1 1.55 1.55 0 0 0 0 3.1zM18.34 18v-4.31c0-2.31-1.23-3.39-2.87-3.39-1.32 0-1.92.73-2.25 1.24v-1.4h-2.67c.04.76 0 7.86 0 7.86h2.67v-4.4c0-.24.02-.48.09-.65.19-.48.63-.97 1.37-.97.97 0 1.36.74 1.36 1.82V18h2.3z"/></svg>',
  },
  {
    name: 'X / Twitter',
    href: `https://twitter.com/intent/tweet?text=${enc(title)}&url=${enc(url)}`,
    icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2H21.5l-7.5 8.575L23 22h-6.844l-5.36-7.013L4.5 22H1.244l8.04-9.193L1 2h7.018l4.846 6.413L18.244 2zm-1.2 18h1.88L7.04 4H5.04l12 16z"/></svg>',
  },
  {
    name: lang === 'fr' ? 'Email' : 'Email',
    href: `mailto:?subject=${enc(title)}&body=${enc(url)}`,
    icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><polyline points="3 7 12 13 21 7"/></svg>',
  },
];

const shareLabel = lang === 'fr' ? 'Partager' : 'Share';
const copyLabel = lang === 'fr' ? 'Copier le lien' : 'Copy link';
const copiedLabel = lang === 'fr' ? 'Lien copié' : 'Link copied';
---

<div class="share-buttons flex flex-wrap items-center gap-2" data-share>
  <span class="text-xs uppercase tracking-wider text-ink-400 mr-1">{shareLabel}</span>

  {channels.map((c) => (
    <a
      href={c.href}
      target="_blank"
      rel="noopener nofollow"
      aria-label={`${shareLabel} — ${c.name}`}
      class="inline-flex items-center justify-center w-9 h-9 rounded-md border border-ink-700 text-ink-300 hover:text-ink-50 hover:bg-ink-800 hover:border-ink-600 transition-colors"
    >
      <span set:html={c.icon} />
    </a>
  ))}

  <button
    type="button"
    data-share-copy={url}
    data-share-copied={copiedLabel}
    data-share-default={copyLabel}
    aria-label={copyLabel}
    class="inline-flex items-center gap-1.5 px-3 h-9 rounded-md border border-ink-700 text-small text-ink-300 hover:text-ink-50 hover:bg-ink-800 hover:border-ink-600 transition-colors"
  >
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
    <span data-share-label>{copyLabel}</span>
  </button>
</div>

<script>
  function setupShare() {
    document.querySelectorAll<HTMLButtonElement>('[data-share-copy]').forEach((btn) => {
      if (btn.dataset.shareBound) return;
      btn.dataset.shareBound = '1';
      btn.addEventListener('click', async () => {
        const url = btn.dataset.shareCopy ?? '';
        const label = btn.querySelector<HTMLElement>('[data-share-label]');
        try {
          await navigator.clipboard.writeText(url);
          if (label) label.textContent = btn.dataset.shareCopied ?? 'Copied';
          (window as any).showToast?.(btn.dataset.shareCopied ?? 'Copied', { variant: 'success', duration: 1800 });
          window.setTimeout(() => {
            if (label) label.textContent = btn.dataset.shareDefault ?? 'Copy';
          }, 1800);
        } catch {
          /* clipboard non disponible */
        }
      });
    });
  }
  setupShare();
  document.addEventListener('astro:page-load', setupShare);
</script>
