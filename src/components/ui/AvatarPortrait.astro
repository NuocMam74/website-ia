---
/**
 * Avatar premium : utilisé tant qu'on n'a pas de vraies photos.
 * - Génère un visage géométrique abstrait (cercles + arcs) dans un
 *   carré avec gradient et halo coloré par famille.
 * - Initiales du nom en filigrane si pas d'icône.
 *
 * Quand de vraies photos seront disponibles, on remplace le SVG par
 * un <img> et on garde le wrapper / l'anneau.
 */
import Icon from './Icon.astro';

interface Props {
  name: string;
  accent?: 'teal' | 'coral' | 'amber';
  icon?: string;
  size?: number;
  class?: string;
}

const {
  name,
  accent = 'teal',
  icon,
  size = 96,
  class: className = '',
} = Astro.props;

const initials = name
  .replace(/\[.*?\]/g, '')          // retire les placeholders entre crochets
  .trim()
  .split(/\s+/)
  .map((s) => s[0])
  .filter(Boolean)
  .slice(0, 2)
  .join('')
  .toUpperCase() || '?';

const grad: Record<'teal' | 'coral' | 'amber', { from: string; to: string; halo: string }> = {
  teal:  { from: '#00D9FF', to: '#008FA8', halo: 'rgba(0,217,255,0.4)' },
  coral: { from: '#FF3D7F', to: '#B81654', halo: 'rgba(255,61,127,0.4)' },
  amber: { from: '#FFB000', to: '#B87B00', halo: 'rgba(255,176,0,0.4)' },
};
const g = grad[accent];
const uid = `av-${Math.random().toString(36).slice(2, 8)}`;
---

<div
  class:list={['relative inline-block', className]}
  style={`width: ${size}px; height: ${size}px;`}
>
  {/* Halo */}
  <div
    class="absolute inset-0 rounded-2xl blur-2xl opacity-60"
    style={`background: radial-gradient(circle at 30% 30%, ${g.halo} 0%, transparent 70%);`}
    aria-hidden="true"
  ></div>

  <div
    class="relative w-full h-full rounded-2xl overflow-hidden ring-1 ring-white/10"
    style={`background: linear-gradient(135deg, ${g.from} 0%, ${g.to} 100%);`}
  >
    {/* Trame géométrique abstraite (suggère une "tête" stylisée) */}
    <svg
      viewBox="0 0 100 100"
      class="absolute inset-0 w-full h-full opacity-20"
      aria-hidden="true"
    >
      <defs>
        <radialGradient id={`${uid}-bg`} cx="50%" cy="40%" r="60%">
          <stop offset="0%" stop-color="rgba(255,255,255,0.6)" />
          <stop offset="100%" stop-color="rgba(255,255,255,0)" />
        </radialGradient>
      </defs>
      <rect width="100" height="100" fill={`url(#${uid}-bg)`} />
      <circle cx="50" cy="38" r="14" fill="rgba(255,255,255,0.18)" />
      <ellipse cx="50" cy="80" rx="28" ry="22" fill="rgba(255,255,255,0.14)" />
      <circle cx="50" cy="38" r="22" stroke="rgba(255,255,255,0.15)" fill="none" stroke-width="0.5" />
    </svg>

    {/* Contenu : icône si fournie, sinon initiales */}
    <div class="absolute inset-0 flex items-center justify-center text-white">
      {icon ? (
        <Icon name={icon} size={Math.round(size / 3)} />
      ) : (
        <span
          class="font-semibold tracking-tight"
          style={`font-size: ${Math.round(size / 3)}px; text-shadow: 0 2px 8px rgba(0,0,0,0.3);`}
        >
          {initials}
        </span>
      )}
    </div>

    {/* Bord lumineux haut */}
    <div class="absolute inset-x-0 top-0 h-px bg-white/30" aria-hidden="true"></div>
  </div>
</div>
