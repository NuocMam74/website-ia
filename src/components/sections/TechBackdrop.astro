---
/**
 * Décor d'ambiance — rappels tech / IA / digital.
 *
 * Plusieurs éléments distincts, hand-placed en position fixe sur le
 * viewport (donc visibles indépendamment du scroll). Pas d'animation,
 * opacité moyenne (10-15%) pour rester présents sans étouffer le
 * contenu. Aucun pattern répétitif "généré".
 *
 * 1. Réseau de nœuds (top-right)        → AI / graph / agents
 * 2. Snippet de code (top-left)         → software / dev
 * 3. Schéma puce (bottom-right)         → hardware / compute
 * 4. Compteur cote technique (bottom-left) → ingénierie
 */
---

<div
  class="fixed inset-0 -z-10 overflow-hidden pointer-events-none"
  aria-hidden="true"
>
  {/* === 1. Réseau de nœuds — top-right === */}
  <svg
    class="absolute -top-10 -right-10 w-[420px] h-[420px] opacity-[0.13] text-teal-200"
    viewBox="0 0 400 400"
    fill="none"
    stroke="currentColor"
    stroke-width="0.8"
  >
    {/* Connexions */}
    <g opacity="0.7">
      <line x1="80" y1="120" x2="200" y2="80" />
      <line x1="200" y1="80" x2="320" y2="140" />
      <line x1="80" y1="120" x2="180" y2="200" />
      <line x1="200" y1="80" x2="180" y2="200" />
      <line x1="320" y1="140" x2="180" y2="200" />
      <line x1="180" y1="200" x2="120" y2="280" />
      <line x1="180" y1="200" x2="260" y2="280" />
      <line x1="120" y1="280" x2="260" y2="280" />
      <line x1="260" y1="280" x2="340" y2="220" />
      <line x1="320" y1="140" x2="340" y2="220" />
      <line x1="120" y1="280" x2="60" y2="220" />
      <line x1="80" y1="120" x2="60" y2="220" />
    </g>
    {/* Nœuds */}
    <circle cx="80" cy="120" r="4" fill="currentColor" />
    <circle cx="200" cy="80" r="6" fill="currentColor" />
    <circle cx="320" cy="140" r="4" fill="currentColor" />
    <circle cx="180" cy="200" r="8" fill="currentColor" />
    <circle cx="120" cy="280" r="5" fill="currentColor" />
    <circle cx="260" cy="280" r="5" fill="currentColor" />
    <circle cx="340" cy="220" r="3" fill="currentColor" />
    <circle cx="60" cy="220" r="3" fill="currentColor" />
    {/* Ring autour du nœud central pour suggérer "actif" */}
    <circle cx="180" cy="200" r="14" stroke-dasharray="3 2" opacity="0.5" />
  </svg>

  {/* === 2. Snippet de code — middle-left === */}
  <div
    class="absolute top-[35vh] left-[2vw] font-mono text-[11px] leading-relaxed opacity-[0.10] text-ink-50 max-w-[260px] whitespace-pre tracking-tight"
  >
{`import { Agent } from 'brand-ai'

const agent = new Agent({
  role: 'analyst',
  memory: true,
  tools: ['search', 'rag']
})

await agent.run(task)
// → 0.94s · ok`}
  </div>

  {/* === 3. Schéma puce / processeur — bottom-right === */}
  <svg
    class="absolute bottom-[6vh] right-[3vw] w-[220px] h-[220px] opacity-[0.11] text-ink-200"
    viewBox="0 0 200 200"
    fill="none"
    stroke="currentColor"
    stroke-width="0.8"
  >
    {/* Corps puce */}
    <rect x="50" y="50" width="100" height="100" rx="4" />
    {/* Bord intérieur */}
    <rect x="62" y="62" width="76" height="76" rx="2" stroke-dasharray="2 3" opacity="0.6" />
    {/* Label centré */}
    <text x="100" y="105" text-anchor="middle" fill="currentColor" stroke="none" font-size="10" font-family="ui-monospace, monospace">AI/02</text>
    {/* Pattes — haut */}
    <g stroke-linecap="round">
      <line x1="70" y1="50" x2="70" y2="40" />
      <line x1="85" y1="50" x2="85" y2="40" />
      <line x1="100" y1="50" x2="100" y2="40" />
      <line x1="115" y1="50" x2="115" y2="40" />
      <line x1="130" y1="50" x2="130" y2="40" />
      {/* bas */}
      <line x1="70" y1="150" x2="70" y2="160" />
      <line x1="85" y1="150" x2="85" y2="160" />
      <line x1="100" y1="150" x2="100" y2="160" />
      <line x1="115" y1="150" x2="115" y2="160" />
      <line x1="130" y1="150" x2="130" y2="160" />
      {/* gauche */}
      <line x1="50" y1="70" x2="40" y2="70" />
      <line x1="50" y1="85" x2="40" y2="85" />
      <line x1="50" y1="100" x2="40" y2="100" />
      <line x1="50" y1="115" x2="40" y2="115" />
      <line x1="50" y1="130" x2="40" y2="130" />
      {/* droite */}
      <line x1="150" y1="70" x2="160" y2="70" />
      <line x1="150" y1="85" x2="160" y2="85" />
      <line x1="150" y1="100" x2="160" y2="100" />
      <line x1="150" y1="115" x2="160" y2="115" />
      <line x1="150" y1="130" x2="160" y2="130" />
    </g>
    {/* Encoche d'orientation */}
    <circle cx="60" cy="60" r="2" fill="currentColor" />
  </svg>

  {/* === 4. Annotation cote technique — bottom-left === */}
  <div
    class="absolute bottom-[8vh] left-[3vw] font-mono text-[10px] opacity-[0.11] text-ink-50 leading-tight"
  >
    <div class="tracking-wide">REV. 2.4 · 2025</div>
    <div class="tracking-wide">NODES: 1240</div>
    <div class="tracking-wide">UPTIME: 99.97%</div>
  </div>

  {/* === 5. Subtile aura cyan en haut, pour le rappel "tech glow" sobre === */}
  <div
    class="absolute -top-40 left-1/2 -translate-x-1/2 w-[800px] h-[400px] opacity-[0.06] rounded-full blur-3xl"
    style="background: radial-gradient(circle, #00D9FF 0%, transparent 70%);"
  ></div>
</div>
