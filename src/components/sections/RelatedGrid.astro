---
/**
 * Grille « offres liées » : 3 colonnes desktop, rendu cartes.
 * On garde la responsabilité du rendu de la carte à l'appelant via slot.
 */
interface Props {
  title?: string;
}
const { title } = Astro.props;
---

<section class="py-12 md:py-16">
  <div class="mx-auto max-w-[1200px] px-6">
    {title && (
      <h2 class="text-h2 font-medium text-ink-50 mb-8">{title}</h2>
    )}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <slot />
    </div>
  </div>
</section>
