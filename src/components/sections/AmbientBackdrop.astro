---
/**
 * Décor d'ambiance qui se positionne en absolu derrière toute la page
 * (sous le contenu, au-dessus du body). Plusieurs blobs flous +
 * pattern dots subtil. Donne l'impression d'une atmosphère continue
 * plutôt que d'une succession de blocs empilés.
 *
 * À placer juste après `<main>` ouvrant, ou dans le BaseLayout.
 */
---

<div
  class="fixed inset-0 -z-10 overflow-hidden pointer-events-none"
  aria-hidden="true"
>
  {/* Blobs colorés flottants — chacun se déplace doucement */}
  <div class="absolute -top-40 -left-32 w-[600px] h-[600px] rounded-full opacity-30 blur-3xl animate-blob-a"
       style="background: radial-gradient(circle, rgba(0,217,255,0.45) 0%, transparent 70%);">
  </div>
  <div class="absolute top-1/3 -right-40 w-[500px] h-[500px] rounded-full opacity-25 blur-3xl animate-blob-b"
       style="background: radial-gradient(circle, rgba(255,61,127,0.5) 0%, transparent 70%);">
  </div>
  <div class="absolute bottom-0 left-1/3 w-[700px] h-[700px] rounded-full opacity-20 blur-3xl animate-blob-c"
       style="background: radial-gradient(circle, rgba(255,176,0,0.35) 0%, transparent 70%);">
  </div>

  {/* Grille très subtile en fond, sur toute la page */}
  <div
    class="absolute inset-0 opacity-[0.03]"
    style="background-image: linear-gradient(rgba(255,255,255,1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,1) 1px, transparent 1px); background-size: 64px 64px;"
  ></div>
</div>

<style>
  @keyframes blob-a {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33%      { transform: translate(40px, 60px) scale(1.05); }
    66%      { transform: translate(-30px, 30px) scale(0.95); }
  }
  @keyframes blob-b {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33%      { transform: translate(-50px, 30px) scale(1.08); }
    66%      { transform: translate(30px, -40px) scale(0.92); }
  }
  @keyframes blob-c {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33%      { transform: translate(60px, -40px) scale(0.9); }
    66%      { transform: translate(-40px, 50px) scale(1.1); }
  }
  .animate-blob-a { animation: blob-a 28s ease-in-out infinite; }
  .animate-blob-b { animation: blob-b 32s ease-in-out infinite 2s; }
  .animate-blob-c { animation: blob-c 36s ease-in-out infinite 4s; }

  @media (prefers-reduced-motion: reduce) {
    .animate-blob-a, .animate-blob-b, .animate-blob-c { animation: none; }
  }
</style>
