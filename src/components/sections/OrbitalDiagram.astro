---
/**
 * Diagramme SVG décoratif "orbital nodes" — utilisé en visuel de hero
 * pour l'accueil. Pas d'image bitmap, tout est vectoriel + animé via
 * SMIL/CSS. Suggère un système d'agents/orchestration.
 *
 * Comportement réduit motion : les animations sont coupées via la règle
 * globale dans global.css.
 */
---

<div
  class="relative w-full aspect-square max-w-[480px] mx-auto pointer-events-none select-none"
  aria-hidden="true"
>
  <svg
    viewBox="0 0 480 480"
    class="w-full h-full overflow-visible"
    role="img"
    aria-hidden="true"
  >
    <defs>
      <radialGradient id="hubGrad" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#FFFFFF" stop-opacity="0.95" />
        <stop offset="60%" stop-color="#00D9FF" stop-opacity="0.9" />
        <stop offset="100%" stop-color="#00D9FF" stop-opacity="0" />
      </radialGradient>
      <radialGradient id="nodeTeal" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#00D9FF" />
        <stop offset="100%" stop-color="#008FA8" />
      </radialGradient>
      <radialGradient id="nodeCoral" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#FF3D7F" />
        <stop offset="100%" stop-color="#B81654" />
      </radialGradient>
      <radialGradient id="nodeAmber" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#FFB000" />
        <stop offset="100%" stop-color="#B87B00" />
      </radialGradient>
      <linearGradient id="lineGrad" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#FFFFFF" stop-opacity="0" />
        <stop offset="50%" stop-color="#FFFFFF" stop-opacity="0.25" />
        <stop offset="100%" stop-color="#FFFFFF" stop-opacity="0" />
      </linearGradient>
    </defs>

    {/* Anneaux orbitaux */}
    <g fill="none" stroke="rgba(255,255,255,0.07)" stroke-width="1">
      <circle cx="240" cy="240" r="80" />
      <circle cx="240" cy="240" r="140" />
      <circle cx="240" cy="240" r="200" />
    </g>

    {/* Lignes de connexion (depuis le hub vers chaque nœud) */}
    <g stroke="url(#lineGrad)" stroke-width="1" fill="none">
      <line x1="240" y1="240" x2="320" y2="160" />
      <line x1="240" y1="240" x2="160" y2="160" />
      <line x1="240" y1="240" x2="360" y2="280" />
      <line x1="240" y1="240" x2="120" y2="280" />
      <line x1="240" y1="240" x2="240" y2="380" />
      <line x1="240" y1="240" x2="240" y2="120" />
    </g>

    {/* Hub central (lueur) */}
    <circle cx="240" cy="240" r="60" fill="url(#hubGrad)" class="animate-pulse-soft" />
    <circle cx="240" cy="240" r="14" fill="#FFFFFF" />

    {/* Nœuds satellites — rotation lente autour du centre */}
    <g style="transform-origin: 240px 240px; animation: orbitSpin 60s linear infinite;">
      <circle cx="320" cy="160" r="10" fill="url(#nodeTeal)" />
      <circle cx="160" cy="160" r="8" fill="url(#nodeCoral)" />
      <circle cx="360" cy="280" r="9" fill="url(#nodeAmber)" />
      <circle cx="120" cy="280" r="7" fill="url(#nodeTeal)" />
      <circle cx="240" cy="380" r="9" fill="url(#nodeCoral)" />
      <circle cx="240" cy="120" r="8" fill="url(#nodeAmber)" />
    </g>

    {/* Particules périphériques — rotation inverse */}
    <g
      fill="rgba(255,255,255,0.4)"
      style="transform-origin: 240px 240px; animation: orbitSpinReverse 90s linear infinite;"
    >
      <circle cx="60" cy="240" r="2" />
      <circle cx="420" cy="240" r="2" />
      <circle cx="380" cy="100" r="2" />
      <circle cx="100" cy="380" r="2" />
      <circle cx="380" cy="380" r="2" />
      <circle cx="100" cy="100" r="2" />
    </g>
  </svg>
</div>

<style>
  @keyframes orbitSpin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }
  @keyframes orbitSpinReverse {
    from { transform: rotate(0deg); }
    to   { transform: rotate(-360deg); }
  }
</style>
