---
/**
 * Accordéon FAQ : utilise <details>/<summary> natifs pour rester
 * accessible et fonctionnel sans JS. Le style supprime juste le marqueur
 * par défaut et ajoute un chevron.
 */
import Icon from '~/components/ui/Icon.astro';

interface Item {
  question: string;
  answer: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---

<div class="divide-y divide-ink-800 border-y border-ink-800">
  {items.map((it) => (
    <details class="group py-4">
      <summary class="flex items-start justify-between gap-4 cursor-pointer list-none">
        <h3 class="text-base font-medium text-ink-50 pr-4">{it.question}</h3>
        <Icon
          name="chevron-down"
          size={20}
          class="text-ink-500 shrink-0 mt-0.5 transition-transform group-open:rotate-180"
        />
      </summary>
      <div class="mt-3 pr-8 text-small text-ink-200 leading-relaxed whitespace-pre-line">
        {it.answer}
      </div>
    </details>
  ))}
</div>

<style>
  /* Supprime le marqueur natif sur tous les navigateurs */
  details > summary { list-style: none; }
  details > summary::-webkit-details-marker { display: none; }
  details > summary::marker { display: none; }
</style>
