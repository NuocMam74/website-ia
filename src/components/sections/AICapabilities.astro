---
/**
 * Vitrine "Capacités IA" — 4 briques fondamentales avec icônes et
 * mini-features. Met l'IA au centre sans la rattacher uniquement à
 * un cas conformité.
 */
import Icon from '~/components/ui/Icon.astro';
import type { Lang } from '~/lib/i18n';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const items = [
  {
    icon: 'bot',
    title: lang === 'fr' ? 'Agents métier' : 'Business agents',
    desc: lang === 'fr'
      ? 'Des agents IA spécialisés par rôle (ingénieur, comptable, support), avec leurs outils et leur mémoire.'
      : 'AI agents specialised by role (engineer, accountant, support), with their tools and memory.',
    features: lang === 'fr'
      ? ['Skills personnalisés', 'Mémoire long-terme', 'Outils MCP/API']
      : ['Custom skills', 'Long-term memory', 'MCP/API tools'],
  },
  {
    icon: 'file-search',
    title: lang === 'fr' ? 'RAG documentaire' : 'Document RAG',
    desc: lang === 'fr'
      ? 'Recherche sémantique sur vos corpus volumineux, avec réponses sourcées et traçabilité complète.'
      : 'Semantic search on large corpora, with grounded answers and full traceability.',
    features: ['pgvector / Qdrant', lang === 'fr' ? 'Citations exactes' : 'Exact citations', 'On-premise OK'],
  },
  {
    icon: 'network',
    title: lang === 'fr' ? 'Orchestration multi-agents' : 'Multi-agent orchestration',
    desc: lang === 'fr'
      ? 'Plusieurs agents qui collaborent : researcher, writer, reviewer. Workflows complexes décomposés et fiabilisés.'
      : 'Multiple agents collaborating: researcher, writer, reviewer. Complex workflows decomposed and reliable.',
    features: ['LangGraph', 'Temporal', lang === 'fr' ? 'Retry & rollback' : 'Retry & rollback'],
  },
  {
    icon: 'sparkles',
    title: lang === 'fr' ? 'Modèles privés' : 'Private models',
    desc: lang === 'fr'
      ? 'Modèles open-source self-hosted (Llama, Mistral), ou clouds privés. Vos données ne sortent pas.'
      : 'Self-hosted open-source models (Llama, Mistral) or private clouds. Your data stays in.',
    features: ['Llama 3', 'Mistral', 'vLLM / Ollama'],
  },
];
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-5">
  {items.map((item, i) => (
    <div class="reveal" style={`--reveal-delay: ${i * 100}ms`}>
      <div class="group h-full p-7 bg-ink-900 border border-ink-800 rounded-xl hover-lift hover:border-coral-400/40 transition-all">
        <div class="flex items-start gap-5">
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-gradient-to-br from-coral-400/20 to-coral-600/10 ring-1 ring-coral-400/30 text-coral-200 shrink-0 group-hover:scale-105 transition-transform">
            <Icon name={item.icon} size={22} />
          </div>
          <div class="flex-1">
            <h3 class="text-h3 font-semibold text-ink-50 tracking-tight">{item.title}</h3>
            <p class="mt-2 text-small text-ink-300 leading-relaxed">{item.desc}</p>

            <div class="mt-4 flex flex-wrap gap-1.5">
              {item.features.map((f) => (
                <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-mono bg-ink-800 text-coral-200 border border-coral-400/20">
                  {f}
                </span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  ))}
</div>
