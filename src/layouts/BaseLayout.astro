---
import '~/styles/global.css';
import { ClientRouter } from 'astro:transitions';
import SiteHeader from '~/components/layout/SiteHeader.astro';
import SiteFooter from '~/components/layout/SiteFooter.astro';
import CookieBanner from '~/components/islands/CookieBanner.tsx';
import TechBackdrop from '~/components/sections/TechBackdrop.astro';
import { type Lang, t, DEFAULT_LANG } from '~/lib/i18n';
import { canonicalUrl, hreflangAlternates, absoluteUrl } from '~/lib/seo';

interface Props {
  /** Titre de la page (sera complété par la marque). */
  title: string;
  description: string;
  /** Chemin SANS préfixe de langue (`/solutions/aspice-navigator`). */
  path: string;
  lang: Lang;
  /** URL OG personnalisée (sinon image par défaut). */
  ogImage?: string;
  noindex?: boolean;
  /** Structured data JSON-LD additionnelles. */
  jsonLd?: object | object[];
}

const {
  title,
  description,
  path,
  lang,
  ogImage,
  noindex = false,
  jsonLd,
} = Astro.props;

const brand = t(lang, 'brand');
const fullTitle = title.includes(brand) ? title : `${title} — ${brand}`;
const canonical = canonicalUrl(path, lang);
const alternates = hreflangAlternates(path);
const ogImageAbs = ogImage ? absoluteUrl(ogImage) : absoluteUrl('/og-default.png');
const ldArray = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<!doctype html>
<html lang={lang} dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#0E1118" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <link rel="canonical" href={canonical} />
    {alternates.map((alt) => (
      <link rel="alternate" hreflang={alt.lang === 'fr' ? 'fr-FR' : 'en-US'} href={alt.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={alternates.find((a) => a.lang === DEFAULT_LANG)!.href} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:locale" content={lang === 'fr' ? 'fr_FR' : 'en_US'} />
    <meta property="og:site_name" content={brand} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />

    <!-- Inter (FOIT évité via swap) -->
    <link rel="preconnect" href="https://rsms.me/" crossorigin />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />

    {ldArray.map((ld) => (
      <script type="application/ld+json" set:html={JSON.stringify(ld)} />
    ))}

    <!-- Page transitions Astro (fade subtil entre pages) -->
    <ClientRouter />

    <!-- Scroll-reveal + cursor-spotlight : deux interactions natives, sans
         dépendance, recâblées après chaque transition de page Astro. -->
    <script>
      function setupReveal() {
        const els = document.querySelectorAll('.reveal:not(.is-visible)');
        if (!('IntersectionObserver' in window)) {
          els.forEach((el) => el.classList.add('is-visible'));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -40px 0px' },
        );
        els.forEach((el) => io.observe(el));
      }

      function setupSpotlight() {
        const els = document.querySelectorAll<HTMLElement>('[data-spotlight]');
        els.forEach((el) => {
          if (el.dataset.spotlightBound) return;
          el.dataset.spotlightBound = '1';
          el.addEventListener('pointermove', (e: PointerEvent) => {
            const rect = el.getBoundingClientRect();
            el.style.setProperty('--mx', `${e.clientX - rect.left}px`);
            el.style.setProperty('--my', `${e.clientY - rect.top}px`);
          });
        });
      }

      setupReveal();
      setupSpotlight();
      document.addEventListener('astro:page-load', () => {
        setupReveal();
        setupSpotlight();
      });
    </script>

    {/*
      Analytics — placeholder à brancher selon le choix d'outil (Plausible,
      Umami, etc.). Le script doit être conditionné au consentement (cf. §20)
      en lisant window.__consent posé par CookieBanner. Exemple :

      <script>
        if (window.__consent === 'accepted') {
          const s = document.createElement('script');
          s.src = 'https://plausible.io/js/script.js';
          s.dataset.domain = location.hostname;
          document.head.appendChild(s);
        }
      </script>
    */}
  </head>
  <body class="min-h-screen flex flex-col">
    <TechBackdrop />
    <a href="#main" class="skip-link">{t(lang, 'nav.skipToContent')}</a>
    <SiteHeader lang={lang} path={path} />
    <main id="main" class="flex-1 relative">
      <slot />
    </main>
    <SiteFooter lang={lang} />
    <CookieBanner client:idle lang={lang} />
  </body>
</html>
