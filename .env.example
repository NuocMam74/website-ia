# URL publique du site (utilisée pour sitemap, OG, canonicals)
SITE_URL=https://example.com

# Stripe (secrets serveur — ne jamais exposer côté client)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend (emails transactionnels)
RESEND_API_KEY=
CONTACT_TO_EMAIL=contact@example.com

# Anti-spam (hCaptcha) — optionnel
HCAPTCHA_SECRET=
